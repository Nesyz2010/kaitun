local function getNearestChest()
    local best, bestDist = nil, math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        local n = obj.Name:lower()
        if n:find("chest") then
            local part = nil

            if obj:IsA("BasePart") then
                part = obj
            elseif obj:IsA("Model") then
                part = obj:FindFirstChildWhichIsA("BasePart")
            end

            if part then
                local dist = (part.Position - getHRP().Position).Magnitude
                if dist < bestDist then
                    best = part
                    bestDist = dist
                end
            end
        end
    end

    return best
end

local function farmChestUntilFist()
    status("Farm chest for Fist of Darkness")

    local loopCount = 0

    while getgenv().CYBORG_AUTO and not hasItem("Fist of Darkness") do
        loopCount += 1

        local chest = getNearestChest()
        if chest then
            status("Collect chest")
            tweenTo(chest.CFrame + Vector3.new(0, 3, 0))
            task.wait(0.25)
        else
            for _, cf in ipairs(ChestSpots) do
                if hasItem("Fist of Darkness") then break end
                tweenTo(cf + Vector3.new(0, 3, 0))
                task.wait(0.25)
            end
        end

        if loopCount % 5 == 0 and getgenv().AutoHopNoChest then
            HopServer("No Fist")
            task.wait(10)
        end

        task.wait(0.2)
    end

    return hasItem("Fist of Darkness")
end

