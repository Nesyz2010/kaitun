-- ══════════════════════════════════════════
--  CHARACTER HELPERS
-- ══════════════════════════════════════════
local function getChar()
    return LP.Character or LP.CharacterAdded:Wait()
end

local function waitAlive()
    local char = getChar()
    local hum  = char:WaitForChild("Humanoid", 20)
    local hrp  = char:WaitForChild("HumanoidRootPart", 20)

    while getgenv().CYBORG_AUTO and (not hum or hum.Health <= 0 or not hrp) do
        LP.CharacterAdded:Wait()
        task.wait(1.5)
        char = getChar()
        hum  = char:WaitForChild("Humanoid", 20)
        hrp  = char:WaitForChild("HumanoidRootPart", 20)
    end

    return char, hum, hrp
end

local function getHRP()
    local _, _, hrp = waitAlive()
    return hrp
end

local function getHum()
    local _, hum = waitAlive()
    return hum
end

-- ══════════════════════════════════════════
--  HARD TELEPORT
-- ══════════════════════════════════════════
local function hardTP(cf)
    local char, hum, hrp = waitAlive()
    if not hrp then return false end

    pcall(function()
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide  = false
                v.Velocity    = Vector3.zero
                v.RotVelocity = Vector3.zero
            end
        end
    end)

    pcall(function()
        if hum.Sit then
            hum.Sit  = false
            hum.Jump = true
        end
    end)

    hrp.CFrame = cf
    task.wait(getgenv().HardTpDelay or 0.12)
    return true
end

-- ══════════════════════════════════════════
--  SAFE INVOKE
-- ══════════════════════════════════════════
local function safeInvoke(...)
    local args = {...}
    local ok, res = pcall(function()
        return CommF:InvokeServer(table.unpack(args))
    end)
    if ok then return res end
    warn("[CYBORG] Invoke error:", res)
    return nil
end

