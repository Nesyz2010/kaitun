-- ══════════════════════════════════════════
--  ORDER RAID
-- ══════════════════════════════════════════
local function startOrderRaid()
    status("Start Order Raid")
    clickAllLabButtons()
    task.wait(5)
end

local function findOrderBoss()
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return nil end
    for _, v in ipairs(enemies:GetChildren()) do
        if v.Name:lower():find("order")
            and v:FindFirstChild("Humanoid")
            and v:FindFirstChild("HumanoidRootPart")
            and v.Humanoid.Health > 0
        then
            return v
        end
    end
    return nil
end

local function attackOrderBoss()
    local boss = findOrderBoss()
    if not boss then return false end

    status("Attack Order Boss")
    equipMelee()

    repeat
        task.wait(0.08)
        pcall(function()
            if not boss.Parent or not boss:FindFirstChild("HumanoidRootPart") then return end

            hardTP(boss.HumanoidRootPart.CFrame * CFrame.new(0, 25, 8))

            local net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
            net:WaitForChild("RE/RegisterAttack"):FireServer(0)

            local head = boss:FindFirstChild("Head") or boss.HumanoidRootPart
            net:WaitForChild("RE/RegisterHit"):FireServer(head, {{boss, boss.HumanoidRootPart}})
        end)
    until not getgenv().CYBORG_AUTO
        or not boss.Parent
        or not boss:FindFirstChild("Humanoid")
        or boss.Humanoid.Health <= 0
        or hasItem("Core Brain")

    status("Order Boss done")
    task.wait(2)
    return true
end

local function runOrderUntilCoreBrain()
    local orderAttempt = 0
    while getgenv().CYBORG_AUTO and not hasItem("Core Brain") do
        orderAttempt += 1
        status("Order attempt #" .. orderAttempt)

        buyMicrochip()
        startOrderRaid()

        local started = tick()
        repeat
            task.wait(0.8)
            if hasItem("Core Brain") then break end
            local boss = findOrderBoss()
            if boss then
                attackOrderBoss()
            else
                status("Waiting Order Boss...")
            end
        until hasItem("Core Brain") or tick() - started > 120  -- tăng 90 → 120s

        if not hasItem("Core Brain") then
            status("No Core Brain → retry Order")
            task.wait(3)
        end
    end
    return hasItem("Core Brain")
end

