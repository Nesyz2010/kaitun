    for _, tool in ipairs(bp:GetChildren()) do
        if tool:IsA("Tool") and tool.ToolTip == "Melee" then
            getHum():EquipTool(tool)
            return
        end
    end

    for _, tool in ipairs(bp:GetChildren()) do
        if tool:IsA("Tool") then
            getHum():EquipTool(tool)
            return
        end
    end
end

