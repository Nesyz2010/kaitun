-- ══════════════════════════════════════════
--  FAST CHEST FARM
--  - Không scan workspace
--  - Cache HRP, chỉ refresh khi chết
--  - Press E sau mỗi spot
--  - Delay tối thiểu 0.04s
-- ══════════════════════════════════════════
local function farmChestUntilFist()
    status("Farm chest → Fist of Darkness")
    local loopCount = 0
    local total     = #ChestSpots

    while getgenv().CYBORG_AUTO and not hasItem("Fist of Darkness") do
        loopCount += 1

        -- Cache char + HRP một lần cho cả vòng
        local char, hum, hrp = waitAlive()
        if not hrp then task.wait(1); continue end

        for i, cf in ipairs(ChestSpots) do
            if not getgenv().CYBORG_AUTO or hasItem("Fist of Darkness") then break end

            -- Refresh HRP nếu character đổi (chết/respawn)
            if not hrp or not hrp.Parent then
                char, hum, hrp = waitAlive()
                if not hrp then break end
            end

            -- Disable collision nhanh
            pcall(function()
                for _, v in ipairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)

            -- Teleport thẳng, không gọi hardTP để tránh overhead
            hrp.CFrame = cf + Vector3.new(0, 3, 0)

            -- Press E để mở chest
            pressE()

            -- Log mỗi 10 spot thôi để không spam
            if i % 10 == 0 then
                status(("Loop %d | Spot %d/%d"):format(loopCount, i, total))
            end

            task.wait(0.04)
        end

        status("Loop " .. loopCount .. " done")

        -- Auto hop sau N vòng không ra Fist
        local hopAfter = getgenv().AutoHopNoFistAfterLoops or 0
        if hopAfter > 0 and loopCount >= hopAfter and not hasItem("Fist of Darkness") then
            status("No Fist after " .. loopCount .. " loops → Hop")
            HopServer("No Fist After Loops")
            task.wait(10)
            loopCount = 0
        end
    end

    if hasItem("Fist of Darkness") then
        status("✓ Got Fist of Darkness!")
    end
    return hasItem("Fist of Darkness")
end

