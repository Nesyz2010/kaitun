-- ══════════════════════════════════════════
--  HOP SERVER
-- ══════════════════════════════════════════
local TriedServers = {}

local function cleanTried()
    for jobId, tm in pairs(TriedServers) do
        if os.time() - tm > 600 then TriedServers[jobId] = nil end
    end
end

local function HopServer(reason)
    cleanTried()
    local browser = ReplicatedStorage:FindFirstChild("__ServerBrowser")
    if not browser then
        warn("[CYBORG] No __ServerBrowser")
        return false
    end

    local all = {}
    for page = 1, 100 do
        local ok, data = pcall(function()
            return browser:InvokeServer(page)
        end)
        if ok and type(data) == "table" then
            for jobId, v in pairs(data) do
                local count = tonumber(v.Count) or 99
                if jobId ~= game.JobId
                    and not TriedServers[jobId]
                    and count <= getgenv().HopMaxPlayers
                then
                    table.insert(all, { JobId = jobId, Count = count })
                end
            end
        end
        if #all > 0 then break end
    end

    table.sort(all, function(a, b) return a.Count < b.Count end)
    local chosen = all[1]
    if not chosen then
        status("No server found")
        return false
    end

    TriedServers[chosen.JobId] = os.time()
    status("Hop → " .. chosen.JobId:sub(1,8) .. " (" .. chosen.Count .. "p)")

    pcall(function()
        browser:InvokeServer("teleport", chosen.JobId)
    end)
    return true
end

