local function getNearestChest()
    local best, bestDist = nil, math.huge
    local hrp = getHRP()

    for _, obj in ipairs(workspace:GetDescendants()) do
        local n = obj.Name:lower()
        if n:find("chest") then
            local part

            if obj:IsA("BasePart") then
                part = obj
            elseif obj:IsA("Model") then
                part = obj:FindFirstChildWhichIsA("BasePart")
            end

            if part then
                local dist = (part.Position - hrp.Position).Magnitude
                if dist < bestDist then
                    best = part
                    bestDist = dist
                end
            end
        end
    end

    return best
end

local function farmChestUntilFist()
    status("Farm 50 chest route for Fist of Darkness")
    local loopCount = 0

    while getgenv().CYBORG_AUTO and not hasItem("Fist of Darkness") do
        loopCount += 1

        for i, cf in ipairs(ChestSpots) do
            if not getgenv().CYBORG_AUTO or hasItem("Fist of Darkness") then break end

            local chest = getNearestChest()
            if chest then
                status("Chest nearest")
                hardTP(chest.CFrame + Vector3.new(0, 3, 0))
            else
                status("Chest spot " .. tostring(i) .. "/50")
                hardTP(cf + Vector3.new(0, 3, 0))
            end

            task.wait(0.06)
        end

        status("Chest loop " .. tostring(loopCount) .. " done")

        if getgenv().AutoHopNoFistAfterLoops and getgenv().AutoHopNoFistAfterLoops > 0 then
            if loopCount >= getgenv().AutoHopNoFistAfterLoops and not hasItem("Fist of Darkness") then
                HopServer("No Fist After Chest Loops")
                task.wait(10)
                loopCount = 0
            end
        end
    end

    return hasItem("Fist of Darkness")
end

local SecretLabPos = CFrame.new(-6438, 250, -4501)

local function clickAllLabButtons()
    pcall(function()
        local map = workspace:FindFirstChild("Map")
        if not map then return end

        for _, obj in ipairs(map:GetDescendants()) do
            if obj:IsA("ClickDetector") then
                local full = obj:GetFullName():lower()
                if full:find("raid")
                or full:find("button")
                or full:find("laboratory")
                or full:find("circle")
                or full:find("order")
                then
                    fireclickdetector(obj)
                end
            end
        end
    end)
end

