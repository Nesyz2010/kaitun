--  CLICK DETECTOR — với fallback
-- ══════════════════════════════════════════
local CLICK_KEYWORDS = { "raid", "button", "laboratory", "circle", "order", "fist", "insert" }

local function clickAllLabButtons()
    pcall(function()
        local map = workspace:FindFirstChild("Map")
        if not map then return end

        for _, obj in ipairs(map:GetDescendants()) do
            if obj:IsA("ClickDetector") then
                local full = obj:GetFullName():lower()
                local match = false
                for _, kw in ipairs(CLICK_KEYWORDS) do
                    if full:find(kw) then match = true; break end
                end
                if match then
                    -- Fallback: thử cả 2 cách
                    pcall(function() fireclickdetector(obj) end)
                    pcall(function() obj:MouseClick(LP) end)
                end
            end
        end
    end)
end

