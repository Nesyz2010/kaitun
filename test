--  HAKI RAINBOW
--  Boss order: Stone → Hydra Leader → Kilo Admiral
--              → Captain Elephant → Beautiful Pirate
--  Lặp cho đến khi có Rainbow Haki
--  Hop nếu không tìm thấy mob sau 5 giây
-- ══════════════════════════════════════════
local RAINBOW_BOSSES = {
    {
        name     = "Stone",
        questKey = "Stone",
        npc      = "HornedMan",
        spawn    = CFrame.new(-1086, 38, 6768),
        entrance = nil,
    },
    {
        name     = "Hydra Leader",
        questKey = "Hydra Leader",
        npc      = "HornedMan",
        spawn    = CFrame.new(5821, 1019, -73),
        entrance = Vector3.new(5643, 1013, -340),
    },
    {
        name     = "Kilo Admiral",
        questKey = "Kilo Admiral",
        npc      = "HornedMan",
        spawn    = CFrame.new(2877, 423, -7207),
        entrance = nil,
    },
    {
        name     = "Captain Elephant",
        questKey = "Captain Elephant",
        npc      = "HornedMan",
        spawn    = CFrame.new(-13376, 433, -8071),
        entrance = Vector3.new(-12462, 375, -7552),
    },
    {
        name     = "Beautiful Pirate",
        questKey = "Beautiful Pirate",
        npc      = "HornedMan",
        spawn    = CFrame.new(5241, 89, 199),
        entrance = Vector3.new(5314, 22, -125),
    },
}

local HORNED_MAN_POS = CFrame.new(-11892, 930, -8760)

local function hasRainbowHaki()
    -- Check inventory hoặc character attribute
    local ok, val = pcall(function()
        return LP.Data.Haki.Value == "Rainbow"
            or LP.Data.Haki.Value == "rainbow"
    end)
    if ok and val then return true end

    -- fallback check item
    local inv = safeInvoke("getInventory")
    if type(inv) == "table" then
        for _, v in pairs(inv) do
            if tostring(v.Name):lower():find("rainbow") then
                return true
            end
        end
    end
    return false
end

local function requestEntranceHaki(pos)
    if not pos then return end
    pcall(function()
        CommF:InvokeServer("requestEntrance", pos)
    end)
    task.wait(1)
end

local function acceptHakiQuest()
    -- Đi tới HornedMan nhận bet
    tweenTo(HORNED_MAN_POS)
    task.wait(1)
    safeInvoke("HornedMan", "Bet")
    task.wait(1)
    return isQuestActive()
end

local function farmRainbowBoss(boss)
    -- Di chuyển tới spawn boss
    if boss.entrance then
        requestEntranceHaki(boss.entrance)
    end
    tweenTo(boss.spawn)
    task.wait(1)

    -- Tìm mob
    local mob = findMob({boss.name})
    if not mob then
        guiLog("Không thấy " .. boss.name .. " (5s) → Hop")
        task.wait(5)
        mob = findMob({boss.name})
        if not mob then
            HopServer("No " .. boss.name)
            task.wait(8)
            return false
        end
    end

    guiLog("Attack: " .. boss.name)
    equipMelee()

    repeat
        task.wait(0.08)
        pcall(function()
            if not mob.Parent or mob.Humanoid.Health <= 0 then return end
            tweenTo(mob.HumanoidRootPart.CFrame * CFrame.new(0, 20, 6))
            attackNearby()
        end)
    until not mob.Parent
        or not mob:FindFirstChild("Humanoid")
        or mob.Humanoid.Health <= 0
        or not isQuestActive()
        or not getgenv().FARM_RUNNING

    guiLog("✓ " .. boss.name .. " done")
    task.wait(1)
    return true
end

local function farmHakiRainbow()
    guiLog("Phase 3: Haki Rainbow")
    hdr.Text      = "FARM HAKI RAINBOW"
    hdr.TextColor3 = Color3.fromRGB(180, 100, 255)

    while getgenv().FARM_RUNNING and not hasRainbowHaki() do

        -- Nhận quest từ HornedMan nếu chưa có
        if not isQuestActive() then
            guiLog("Nhận quest HornedMan...")
            local ok = acceptHakiQuest()
            if not ok then
                guiLog("Không nhận được quest → thử lại")
                task.wait(2)
                continue
            end
        end

        local title = getQuestTitle()
        guiLog("Quest: " .. title)

        -- Tìm boss tương ứng
        local matched = nil
        for _, boss in ipairs(RAINBOW_BOSSES) do
            if title:find(boss.questKey) then
                matched = boss
                break
            end
        end

        if matched then
            farmRainbowBoss(matched)
        else
            guiLog("Quest không khớp boss nào: " .. title)
            task.wait(2)
        end
    end

    if hasRainbowHaki() then
        guiLog("✓ RAINBOW HAKI DONE!")
    end
end

-- ══════════════════════════════════════════
--  UPDATE PROGRESS (override để thêm haki)
-- ══════════════════════════════════════════
local function updateProgress()
    local scale = countItem("Dragon Scale")
    local blaze = countItem("Blaze Ember")
    local haki  = hasRainbowHaki() and "✓" or "✗"
    progLbl.Text = ("Scale:%d/5 Blaze:%d/45 Haki:%s"):format(
        scale, blaze, haki
    )
end

