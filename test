local HYDRA_SPAWN = CFrame.new(5821, 1019, -73)
local DRAGON_MOBS = {"Dragon Crew Warrior", "Dragon Crew Archer"}

local function farmDragonScale()
    guiLog("Farm Dragon Scale...")
    equipMelee()

    while getgenv().FARM_RUNNING
        and countItem("Dragon Scale") < TARGET_DRAGON_SCALE
    do
        updateProgress()

        local mob = findMob(DRAGON_MOBS)
        if not mob then
            guiLog("Không thấy Dragon mob → di chuyển tới Hydra Island")
            safeInvoke("requestEntrance",
                Vector3.new(5643, 1013, -340))
            task.wait(1)
            tweenTo(HYDRA_SPAWN)
            task.wait(2)
            mob = findMob(DRAGON_MOBS)
        end

        if mob then
            guiLog("Attack: " .. mob.Name)
            repeat
                task.wait(0.08)
                pcall(function()
                    if not mob.Parent or mob.Humanoid.Health <= 0 then return end
                    tweenTo(mob.HumanoidRootPart.CFrame * CFrame.new(0, 20, 6))
                    attackNearby()
                end)
            until not mob.Parent
                or not mob:FindFirstChild("Humanoid")
                or mob.Humanoid.Health <= 0
                or countItem("Dragon Scale") >= TARGET_DRAGON_SCALE

            task.wait(0.5)
        else
            task.wait(1)
        end
    end

    guiLog("✓ Dragon Scale: " .. countItem("Dragon Scale") .. "/5")
end

