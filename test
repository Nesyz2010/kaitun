--  Quest: Venomous Assailant hoặc Hydra Enforcer
--  Hop nếu ra quest Trees
-- ══════════════════════════════════════════
local BLAZE_NPC_POS   = CFrame.new(5780, 1010, -200)  -- NPC quest gần Hydra Island

-- Mob positions
local VENOMOUS_SPAWN  = CFrame.new(5600, 1013, -500)
local HYDRA_ENF_SPAWN = CFrame.new(5700, 1013, -150)

local VENOMOUS_MOBS   = {"Venomous Assailant"}
local HYDRA_ENF_MOBS  = {"Hydra Enforcer"}

local function acceptBlazeQuest()
    -- Thử nhận quest, check title rồi quyết định
    -- NPC quest Blaze Ember ở Hydra Island
    tweenTo(BLAZE_NPC_POS)
    task.wait(1)

    -- Invoke NPC để nhận quest
    -- Thử các quest khác nhau
    local questNPCs = {
        {"BlazeQuest", "1"},
        {"HydraQuestGiver", "1"},
        {"VenomousQuest", "1"},
    }
    for _, args in ipairs(questNPCs) do
        safeInvoke(table.unpack(args))
        task.wait(0.5)
        if isQuestActive() then break end
    end

    task.wait(0.5)
    local title = getQuestTitle()
    guiLog("Quest: " .. title)

    -- Nếu ra Trees → hop
    if title:lower():find("tree") then
        guiLog("Quest Trees → Hop server!")
        HopServer("QuestTrees")
        task.wait(8)
        return false
    end

    return isQuestActive()
end

local function farmBlazeEmber()
    guiLog("Farm Blaze Ember...")
    equipMelee()

    while getgenv().FARM_RUNNING
        and countItem("Blaze Ember") < TARGET_BLAZE_EMBER
    do
        updateProgress()

        -- Nhận quest
        local questOk = false
        if not isQuestActive() then
            questOk = acceptBlazeQuest()
            if not questOk then task.wait(2); continue end
        end

        local title = getQuestTitle()
        guiLog("Quest active: " .. title)

        -- Farm theo quest
        local mobNames, spawnCF

        if title:lower():find("venomous") then
            mobNames = VENOMOUS_MOBS
            spawnCF  = VENOMOUS_SPAWN
        elseif title:lower():find("hydra enforcer") or title:lower():find("hydra") then
            mobNames = HYDRA_ENF_MOBS
            spawnCF  = HYDRA_ENF_SPAWN
        elseif title:lower():find("tree") then
            guiLog("Quest Trees → Hop!")
            HopServer("QuestTrees")
            task.wait(8)
            continue
        else
            guiLog("Quest không rõ: " .. title .. " → skip")
            task.wait(2)
            continue
        end

        -- Farm mob cho đến khi quest xong
        local questStartBlaze = countItem("Blaze Ember")

        repeat
            local mob = findMob(mobNames)
            if not mob then
                guiLog("Không thấy mob → di chuyển")
                tweenTo(spawnCF)
                task.wait(2)
                mob = findMob(mobNames)
            end

            if mob then
                repeat
                    task.wait(0.08)
                    pcall(function()
                        if not mob.Parent or mob.Humanoid.Health <= 0 then return end
                        tweenTo(mob.HumanoidRootPart.CFrame * CFrame.new(0, 20, 6))
                        attackNearby()
                    end)
                until not mob.Parent
                    or not mob:FindFirstChild("Humanoid")
                    or mob.Humanoid.Health <= 0
                    or not isQuestActive()
                task.wait(0.3)
            else
                task.wait(1)
            end
        until not isQuestActive()
            or not getgenv().FARM_RUNNING

        local newBlaze = countItem("Blaze Ember")
        guiLog(("Blaze Ember: %d → %d"):format(questStartBlaze, newBlaze))
        task.wait(0.5)
    end

    guiLog("✓ Blaze Ember: " .. countItem("Blaze Ember") .. "/45")
end

