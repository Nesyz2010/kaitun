-- Classify log line
local function classifyLine(msg)
    local m = msg:lower()
    if m:find("✓") or m:find("done") or m:find("xong") or m:find("đủ") or m:find("complete") then
        return C.dot_ok, Color3.fromRGB(100, 255, 160)
    elseif m:find("hop") or m:find("travel") or m:find("teleport") then
        return C.dot_warn, Color3.fromRGB(255, 210, 80)
    elseif m:find("lỗi") or m:find("fail") or m:find("error") or m:find("⚠") then
        return C.dot_err, Color3.fromRGB(255, 100, 100)
    elseif m:find("attack") or m:find("farm") or m:find("kill") or m:find("boss") or m:find("phase") then
        return C.dot_info, Color3.fromRGB(120, 210, 255)
    end
    return C.dot_info, C.textMain
end

local function refreshUI()
    for i = 1, MAX_LOG do
        local entry = _lines[i]
        if not entry then
            _texts[i].Text = ""
            _dots[i].BackgroundColor3 = Color3.fromRGB(30, 50, 40)
            _rows[i].BackgroundTransparency = 0.7
        else
            _texts[i].Text             = entry.text
            _texts[i].TextColor3       = entry.color
            _dots[i].BackgroundColor3  = entry.dot
            _rows[i].BackgroundTransparency = 0.4
        end
    end
end

local function guiLog(msg)
    msg = tostring(msg)
    print("[FARM]", msg)
    local dotC, txtC = classifyLine(msg)
    table.insert(_lines, {text = msg, color = txtC, dot = dotC})
    while #_lines > MAX_LOG do table.remove(_lines, 1) end
    refreshUI()
end

