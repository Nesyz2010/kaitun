local function getChar()
    return LP.Character or LP.CharacterAdded:Wait()
end

local function waitAlive()
    local char = getChar()
    local hum  = char:WaitForChild("Humanoid", 10)
    local hrp  = char:WaitForChild("HumanoidRootPart", 10)
    while getgenv().FARM_RUNNING and (not hum or hum.Health <= 0 or not hrp) do
        LP.CharacterAdded:Wait()
        task.wait(1.5)
        char = getChar()
        hum  = char:WaitForChild("Humanoid", 10)
        hrp  = char:WaitForChild("HumanoidRootPart", 10)
    end
    return char, hum, hrp
end

local function getHRP()
    local _, _, hrp = waitAlive()
    return hrp
end

local function getHum()
    local _, hum = waitAlive()
    return hum
end

local function safeInvoke(...)
    local args = {...}
    local ok, res = pcall(function()
        return CommF:InvokeServer(table.unpack(args))
    end)
    return ok and res or nil
end

function countItem(name)
    local count = 0
    local inv = safeInvoke("getInventory")
    if type(inv) == "table" then
        for _, v in pairs(inv) do
            if v.Name == name then
                count = tonumber(v.Count) or 0
            end
        end
    end
    -- fallback: check backpack
    local bp = LP:FindFirstChildOfClass("Backpack")
    local ch = LP.Character
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t.Name == name then count += 1 end
        end
    end
    if ch then
        for _, t in ipairs(ch:GetChildren()) do
            if t.Name == name then count += 1 end
        end
    end
    return count
end

local function hasEnough()
    return countItem("Dragon Scale") >= TARGET_DRAGON_SCALE
        and countItem("Blaze Ember") >= TARGET_BLAZE_EMBER
end

-- ══════════════════════════════════════════
--  TWEEN MOVE
-- ══════════════════════════════════════════
local SPEED = 280

local function tweenTo(cf)
    local hrp = getHRP()
    if not hrp then return end
    pcall(function()
        for _, v in ipairs(getChar():GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end)
    local dist = (hrp.Position - cf.Position).Magnitude
    if dist < 10 then hrp.CFrame = cf; return end
    local tw = TweenService:Create(hrp,
        TweenInfo.new(dist/SPEED, Enum.EasingStyle.Linear),
        {CFrame = cf})
    tw:Play()
    tw.Completed:Wait()
end

