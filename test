task.spawn(function()
    guiLog("FARM LOADED")
    updateProgress()

    ensureSea3()
    waitAlive()

    -- Phase 1: Dragon Scale
    if countItem("Dragon Scale") < TARGET_DRAGON_SCALE then
        guiLog("Phase 1: Dragon Scale")
        hdr.Text = "FARM DRAGON SCALE"
        farmDragonScale()
    else
        guiLog("Dragon Scale đã đủ ✓")
    end

    waitAlive()

    -- Phase 2: Blaze Ember
    if countItem("Blaze Ember") < TARGET_BLAZE_EMBER then
        guiLog("Phase 2: Blaze Ember")
        hdr.Text = "FARM BLAZE EMBER"
        farmBlazeEmber()
    else
        guiLog("Blaze Ember đã đủ ✓")
    end

    waitAlive()
    updateProgress()

    -- Phase 3: Haki Rainbow
    if not hasRainbowHaki() then
        farmHakiRainbow()
    else
        guiLog("Rainbow Haki đã có ✓")
    end

    updateProgress()

    -- Done
    guiLog("✓ ALL DONE!")
    hdr.TextColor3 = Color3.fromRGB(80, 255, 130)
    hdr.Text       = "✓ ALL COMPLETE"
    getgenv().FARM_RUNNING = false
end)
