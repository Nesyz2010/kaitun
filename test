--  ATTACK
-- ══════════════════════════════════════════
local function attackNearby()
    pcall(function()
        local net     = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
        local hrpPos  = getHRP().Position
        local enemies = workspace:FindFirstChild("Enemies")
        if not enemies then return end

        local targets = {}
        for _, mob in ipairs(enemies:GetChildren()) do
            if mob:FindFirstChild("HumanoidRootPart")
                and mob:FindFirstChild("Head")
                and mob:FindFirstChild("Humanoid")
                and mob.Humanoid.Health > 0
                and (mob.HumanoidRootPart.Position - hrpPos).Magnitude <= 60
            then
                table.insert(targets, mob)
            end
        end
        if #targets == 0 then return end

        net:WaitForChild("RE/RegisterAttack"):FireServer(0)
        local args = {nil, {}}
        for i, v in ipairs(targets) do
            if not args[1] then args[1] = v.Head end
            args[2][i] = {v, v.HumanoidRootPart}
        end
        net:WaitForChild("RE/RegisterHit"):FireServer(table.unpack(args))
    end)
end

-- ══════════════════════════════════════════
--  FIND MOB
-- ══════════════════════════════════════════
local function findMob(names)
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return nil end
    local best, bestDist = nil, math.huge
    local hrp = getHRP()
    if not hrp then return nil end
    for _, mob in ipairs(enemies:GetChildren()) do
        if mob:IsA("Model")
            and mob:FindFirstChild("Humanoid")
            and mob:FindFirstChild("HumanoidRootPart")
            and mob.Humanoid.Health > 0
        then
            for _, n in ipairs(names) do
                if mob.Name:find(n) then
                    local d = (mob.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < bestDist then best = mob; bestDist = d end
                    break
                end
            end
        end
    end
    return best
end

-- ══════════════════════════════════════════
--  SERVER HOP
-- ══════════════════════════════════════════
local LastServersDataPulled, CachedServers

local function IfTableHaveIndex(j)
    if type(j) ~= "table" then return false end
    for _ in pairs(j) do return true end
    return false
end

local function GetServers()
    if LastServersDataPulled and CachedServers then
        if os.time() - LastServersDataPulled < 60 then return CachedServers end
    end
    local Browser = ReplicatedStorage:FindFirstChild("__ServerBrowser")
    if not Browser then return nil end
    for i = 1, 100 do
        local ok, data = pcall(function() return Browser:InvokeServer(i) end)
        if ok and IfTableHaveIndex(data) then
            LastServersDataPulled = os.time()
            CachedServers = data
            return data
        end
    end
    return nil
end

local function HopServer(reason)
    guiLog("Hop: " .. (reason or ""))
    local Servers = GetServers()
    if not Servers then return false end

    local arr = {}
    for jobId, v in pairs(Servers) do
        if jobId ~= game.JobId then
            table.insert(arr, {JobId = jobId, Players = tonumber(v.Count) or 99})
        end
    end
    if #arr == 0 then return false end

    -- Spam hop 5 server
    table.sort(arr, function(a, b) return a.Players < b.Players end)
    local SPAM = math.min(5, #arr)
    for i = #arr, 2, -1 do
        local j = math.random(1, i)
        arr[i], arr[j] = arr[j], arr[i]
    end

    local Browser = ReplicatedStorage:FindFirstChild("__ServerBrowser")
    if not Browser then return false end

    for i = 1, SPAM do
        local target = arr[i]
        guiLog(("  → [%s] %dp"):format(target.JobId:sub(1,8), target.Players))
        task.spawn(function()
            pcall(function() Browser:InvokeServer("teleport", target.JobId) end)
        end)
        task.wait(0.05)
    end
    return true
end

