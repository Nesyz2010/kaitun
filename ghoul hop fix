                return newTool
            end
            task.wait(CHECK_EVERY)
        end
        return nil
    end
    
    local function existsInBPOrChar(tool)
        if not tool then return false end
        local ok, parent = pcall(function() return tool.Parent end)
        if not ok or not parent then return false end
    
        local bp = plr:FindFirstChildOfClass("Backpack")
        local ch = plr.Character
        if bp and tool:IsDescendantOf(bp) then return true end
        if ch and tool:IsDescendantOf(ch) then return true end
        return false
    end
    
    local function ensureUnequip()
        pcall(function()
            local ch = plr.Character
            if not ch then return end
            local hum = ch:FindFirstChildOfClass("Humanoid")
            if hum then hum:UnequipTools() end
        end)
    end
    
    local function moveToolToBackpack(tool)
        local bp = plr:FindFirstChildOfClass("Backpack")
        if not bp or not tool then return end
        pcall(function()
            tool.Parent = bp
        end)
    end
    
    local function storeFruitTool(tool)
        if not tool then return false, "no tool" end
    
        safeHideDialogue()
        ensureUnequip()
        task.wait(0.2)
    
        moveToolToBackpack(tool)
        task.wait(0.2)
    
        local nameToStore = toolDisplayName(tool)
        local countBefore = countFruitInBackpackByName(nameToStore)
    
        local ok, res = pcall(function()
            return CommF:InvokeServer("StoreFruit", nameToStore, tool)
        end)
    
        local t0 = os.clock()
        local timeout = 6
        local success = false
    
        while os.clock() - t0 < timeout do
            local stillThere = existsInBPOrChar(tool)
            local countAfter = countFruitInBackpackByName(nameToStore)
    
            if (not stillThere) or (countAfter < countBefore) then
                success = true
                break
            end
    
            task.wait(0.25)
        end
    
        return success, (ok and tostring(res) or "pcall_fail")
    end
    
    local function formatTime(sec)
        sec = math.max(0, math.floor(sec))
        local h = math.floor(sec / 3600)
        local m = math.floor((sec % 3600) / 60)
        local s = sec % 60
        return string.format("%02d:%02d:%02d", h, m, s)
    end
    
    local function cooldownOneHour()
        local endAt = os.clock() + SUCCESS_COOLDOWN
        local lastPrint = 0
    
        while true do
            local left = endAt - os.clock()
            if left <= 0 then break end
    
            if (SUCCESS_COOLDOWN - left) - lastPrint >= 60 then
                lastPrint = (SUCCESS_COOLDOWN - left)
                warn("[RANDOM FRUIT] cooldown còn: " .. formatTime(left))
            end
    
            task.wait(1)
        end
    end
    
    local function sendFruitWebhook(newFruitName, listBefore, storeSuccess, storeRes, listAfter)
        local beforeText = (#listBefore > 0) and table.concat(listBefore, "\n") or "(empty)"
        local afterText  = (#listAfter  > 0) and table.concat(listAfter,  "\n") or "(empty)"
    
        local statusText = storeSuccess and "✅ Store SUCCESS" or "❌ Store UNSUCCESS"
        local ping = isRedFruit(newFruitName)
    
        postWebhook({
            username = "BloxFruit Tracker",
            content = ping
                and ("@everyone | Player: **" .. tostring(plr.Name) .. "** | Fruit: **" .. tostring(newFruitName) .. "**")
                or  ("Player: **" .. tostring(plr.Name) .. "** | Fruit: **" .. tostring(newFruitName) .. "**"),
            allowed_mentions = ping and { parse = { "everyone" } } or { parse = {} },
    
            embeds = {
                {
                    title = ping and "🔥 Mythical Fruit Found!" or "Random Fruit Result",
                    description = "**New Fruit:** " .. tostring(newFruitName) .. "\n" .. statusText,
                    fields = {
                        { name = "Player", value = tostring(plr.Name), inline = true },
                        { name = "UserId", value = tostring(plr.UserId), inline = true },
                        { name = "JobId", value = tostring(game.JobId), inline = false },
    
                        { name = "Backpack Fruits (Before Store)", value = "```" .. clampText(beforeText, 950) .. "```", inline = false },
                        { name = "Store Response", value = "```" .. clampText(storeRes, 950) .. "```", inline = false },
                        { name = "Backpack Fruits (After Store)", value = "```" .. clampText(afterText, 950) .. "```", inline = false },
                    }
                }
            }
        })
    end
    
    local function tryBuyOnce()
        safeHideDialogue()
    
        local prevSet = snapshotFruitSet()
    
        pcall(function()
            CommF:InvokeServer("Cousin", "Buy")
        end)
    
        local newFruit = waitForNewFruit(prevSet, WAIT_FRUIT_APPEAR)
        if newFruit then
            local fruitName = toolDisplayName(newFruit)
            warn("[RANDOM FRUIT] SUCCESS: " .. fruitName)
    
            task.wait(WAIT_BEFORE_STORE)
    
            local before = getFruitNames_Backpack()
            local storeOk, storeRes = storeFruitTool(newFruit)
            local after = getFruitNames_Backpack()
    
            if storeOk then
                warn("[STORE FRUIT] SUCCESS: " .. fruitName)
            else
                warn("[STORE FRUIT] UNSUCCESS: " .. fruitName .. " | res=" .. tostring(storeRes))
            end
    
            sendFruitWebhook(fruitName, before, storeOk, storeRes, after)
            return true
        end
    
        warn("[RANDOM FRUIT] FAIL/COOLDOWN -> sẽ thử lại sau " .. RETRY_INTERVAL .. "s")
        return false
    end
    
    while task.wait(0.2) do
        local success = tryBuyOnce()
        if success then
            cooldownOneHour() -- cooldown in the reply for the for sheet
        else
            task.wait(RETRY_INTERVAL)
        end
    end
end)
