local LastServersDataPulled = nil
local CachedServers = nil

local function IfTableHaveIndex(t)
    if type(t) ~= "table" then
        return false
    end
    for _ in pairs(t) do
        return true
    end
    return false
end

local function GetServers()
    if LastServersDataPulled and CachedServers then
        if os.time() - LastServersDataPulled < 60 then
            return CachedServers
        end
    end

    local Browser = ReplicatedStorage:WaitForChild("__ServerBrowser")
    for i = 1, 100 do
        local ok, data = pcall(function()
            return Browser:InvokeServer(i)
        end)

        if ok and IfTableHaveIndex(data) then
            LastServersDataPulled = os.time()
            CachedServers = data
            return data
        end
    end

    return nil
end

function HopServer(maxPlayers, region)
    maxPlayers = tonumber(maxPlayers) or 10

    local servers = GetServers()
    if not servers then
        warn("[HOP] Không lấy được server list")
        return false
    end

    local list = {}
    for jobId, data in pairs(servers) do
        table.insert(list, {
            JobId = jobId,
            Players = tonumber(data.Count) or 0,
            Region = data.Region
        })
    end

    if #list <= 0 then
        warn("[HOP] Empty server list")
        return false
    end

    local chosen = nil
    for _ = 1, 150 do
        local pick = list[math.random(1, #list)]
        if pick and pick.JobId ~= game.JobId then
            if pick.Players < maxPlayers then
                if (not region or pick.Region == region) then
                    chosen = pick
                    break
                end
            end
        end
    end

    -- fallback: nếu không có server dưới maxPlayers thì chọn server khác bất kỳ trong list
    if not chosen then
        for _, pick in ipairs(list) do
            if pick.JobId ~= game.JobId then
                chosen = pick
                break
            end
        end
    end

    if not chosen then
        warn("[HOP] Không tìm được server phù hợp")
        return false
    end

    print("[HOP] Teleport ->", chosen.JobId, "| Players:", chosen.Players, "| Region:", tostring(chosen.Region))

    local ok, err = pcall(function()
        ReplicatedStorage:WaitForChild("__ServerBrowser"):InvokeServer("teleport", chosen.JobId)
    end)

    if not ok then
        warn("[HOP ERROR]", err)
        return false
    end

    return true
end

